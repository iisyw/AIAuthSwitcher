{
  "name": "ai-auth-switcher",
  "displayName": "AIAuthSwitcher",
  "description": "备份并切换 AI 编码工具的本地授权文件",
  "version": "0.0.1",
  "license": "GPL-3.0-only",
  "keywords": [
    "ai",
    "auth",
    "account",
    "switcher",
    "codex",
    "vscode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iisyw/AIAuthSwitcher.git"
  },
  "homepage": "https://github.com/iisyw/AIAuthSwitcher",
  "bugs": {
    "url": "https://github.com/iisyw/AIAuthSwitcher/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-auth-switcher.showCurrentAccount",
        "title": "AIAuthSwitcher：查看当前账号"
      },
      {
        "command": "ai-auth-switcher.backupCurrentAuth",
        "title": "AIAuthSwitcher：备份当前授权"
      },
      {
        "command": "ai-auth-switcher.importAuthFiles",
        "title": "AIAuthSwitcher：导入",
        "icon": "$(git-stash)"
      },
      {
        "command": "ai-auth-switcher.exportAllBackups",
        "title": "AIAuthSwitcher：导出",
        "icon": "$(git-stash-pop)"
      },
      {
        "command": "ai-auth-switcher.restoreBackupItem",
        "title": "AIAuthSwitcher：恢复授权备份",
        "icon": "$(replace-all)"
      },
      {
        "command": "ai-auth-switcher.deleteBackupItem",
        "title": "AIAuthSwitcher：删除授权备份",
        "icon": "$(trash)"
      },
      {
        "command": "ai-auth-switcher.reloadTargetExtension",
        "title": "AIAuthSwitcher：重载窗口",
        "icon": "$(sync)"
      },
      {
        "command": "ai-auth-switcher.refreshView",
        "title": "AIAuthSwitcher：刷新视图",
        "icon": "$(refresh)"
      },
      {
        "command": "ai-auth-switcher.addAccount",
        "title": "AIAuthSwitcher：添加账号",
        "icon": "$(add)"
      },
      {
        "command": "ai-auth-switcher.refreshCodexAuth",
        "title": "AIAuthSwitcher：刷新 Codex 授权",
        "icon": "$(key)"
      },
      {
        "command": "ai-auth-switcher.fetchCodexUsage",
        "title": "AIAuthSwitcher：查询 Codex 用量",
        "icon": "$(pulse)"
      },
      {
        "command": "ai-auth-switcher.fetchBackupCodexUsage",
        "title": "AIAuthSwitcher：查询备份账号 Codex 用量",
        "icon": "$(pulse)"
      },
      {
        "command": "ai-auth-switcher.fetchAllBackupCodexUsage",
        "title": "AIAuthSwitcher：批量查询备份账号 Codex 用量",
        "icon": "$(pulse)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiAuthSwitcher",
          "title": "AIAuthSwitcher",
          "icon": "media/ai-auth-switcher.svg"
        }
      ]
    },
    "views": {
      "aiAuthSwitcher": [
        {
          "id": "ai-auth-switcher.accountsView",
          "name": "账号"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ai-auth-switcher.refreshView",
          "when": "view == ai-auth-switcher.accountsView",
          "group": "navigation@1"
        },
        {
          "command": "ai-auth-switcher.addAccount",
          "when": "view == ai-auth-switcher.accountsView",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "ai-auth-switcher.showCurrentAccount",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.backupCurrentAuth",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.importAuthFiles",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.exportAllBackups",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.restoreBackupItem",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.deleteBackupItem",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.reloadTargetExtension",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.refreshView",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.addAccount",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.refreshCodexAuth",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.fetchCodexUsage",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.fetchBackupCodexUsage",
          "when": "false"
        },
        {
          "command": "ai-auth-switcher.fetchAllBackupCodexUsage",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "ai-auth-switcher.fetchAllBackupCodexUsage",
          "when": "view == ai-auth-switcher.accountsView && viewItem == authBackupsSection",
          "group": "inline@1"
        },
        {
          "command": "ai-auth-switcher.importAuthFiles",
          "when": "view == ai-auth-switcher.accountsView && viewItem == authBackupsSection",
          "group": "inline@2"
        },
        {
          "command": "ai-auth-switcher.exportAllBackups",
          "when": "view == ai-auth-switcher.accountsView && viewItem == authBackupsSection",
          "group": "inline@3"
        },
        {
          "command": "ai-auth-switcher.fetchBackupCodexUsage",
          "when": "view == ai-auth-switcher.accountsView && viewItem == authBackup",
          "group": "inline@1"
        },
        {
          "command": "ai-auth-switcher.restoreBackupItem",
          "when": "view == ai-auth-switcher.accountsView && viewItem == authBackup",
          "group": "inline@2"
        },
        {
          "command": "ai-auth-switcher.deleteBackupItem",
          "when": "view == ai-auth-switcher.accountsView && viewItem == authBackup",
          "group": "inline@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
